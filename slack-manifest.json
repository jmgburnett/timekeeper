{
  "display_information": {
    "name": "Timekeeper",
    "description": "Weekly time tracking for professional services teams",
    "background_color": "#1e40af"
  },
  "features": {
    "bot_user": {
      "display_name": "Timekeeper",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/timekeeper",
        "url": "https://marvelous-cuttlefish-492.convex.site/slack/commands",
        "description": "Open your weekly time entry",
        "usage_hint": "",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "im:write",
        "im:history",
        "im:read",
        "users:read",
        "commands"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://marvelous-cuttlefish-492.convex.site/slack/events",
      "bot_events": [
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://marvelous-cuttlefish-492.convex.site/slack/interactions"
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
